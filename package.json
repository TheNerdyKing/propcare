{
  "name": "propcare",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm --prefix apps/api run start:dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "postinstall": "cd apps/api && npx prisma generate --schema=prisma/schema.prisma"
  },
  "prisma": {
    "seed": "ts-node apps/api/prisma/seed.ts"
  }
}